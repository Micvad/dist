name: "📺 BiliBili: ⚙️ Enhanced"
desc: |-
  哔哩哔哩：增强模式
  中国站功能增强及UI自定义
openUrl: "http://boxjs.com/#/app/BiliBili.Enhanced"
author: |-
  VirgilClyne[https://github.com/VirgilClyne]
homepage: "https://Enhanced.BiliUniverse.io"
icon: "https://github.com/BiliUniverse/Enhanced/raw/main/src/assets/icon_rounded.png"
category: "🪐 BiliUniverse"
date: "2026-04-26 17:31:36"
version: ""

http:
  mitm:
    - "app.bilibili.com"
    - "app.biliapi.net"
    - "api.live.bilibili.com"
  script:
    - match: ^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/resource\/show\/tab\/v2\?
      name: 馃摵 BiliBili.Enhanced.response
      type: response
      require-body: true
    - match: ^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/account\/mine(\/ipad)?\?
      name: 馃摵 BiliBili.Enhanced.response
      type: response
      require-body: true
    - match: ^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/region\/index\?
      name: 馃摵 BiliBili.Enhanced.response
      type: response
      require-body: true
    - match: ^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/channel\/region\/list\?
      name: 馃摵 BiliBili.Enhanced.response
      type: response
      require-body: true
    - match: ^https?:\/\/api\.live\.bilibili\.com\/xlive\/app-interface\/v2\/index\/feed
      name: 馃摵 BiliBili.Enhanced.response
      type: response
      require-body: true
    - match: ^https?:\/\/api\.live\.bilibili\.com\/xlive\/app-room\/v1\/index\/getInfoByRoom
      name: 馃摵 BiliBili.Enhanced.response
      type: response
      require-body: true

script-providers:
  馃摵 BiliBili.Enhanced.response:
    url: https://raw.githubusercontent.com/Micvad/dist/master/response.bundle.js
    interval: 86400
